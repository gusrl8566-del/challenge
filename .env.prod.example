# Common
TZ=Asia/Seoul

# Frontend domain(s) allowed by backend CORS (comma-separated)
# Example: https://inbody.example.com,https://www.inbody.example.com
FRONTEND_URL=https://inbody.example.com

# Backend auth
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d
ADMIN_SUPER_CODE=CHANGE_ME_ADMIN_CODE

# OCR
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_OCR_MODEL=gpt-4.1

# Database (Postgres)
DB_TYPE=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=inbody
DATABASE_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_NAME=inbody_challenge

# Frontend runtime (optional)
NEXT_PUBLIC_API_URL=https://api.megaworld.store
